<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="MauiFadeToFreezeRepro.MainPage"
             BackgroundColor="Black">

    <Grid RowDefinitions="*, Auto" Padding="20">
        
        <!-- Parent Layout: Toggling IsEnabled on this Grid triggers the bug -->
        <Grid x:Name="MainGrid" Grid.Row="0" VerticalOptions="Center" HorizontalOptions="Center">
            
            <VerticalStackLayout Spacing="20" HorizontalOptions="Center">
                <Label Text=".NET MAUI 10.0.60 iOS Touch Event Bug" 
                       TextColor="White" 
                       FontSize="20" 
                       FontAttributes="Bold" 
                       HorizontalTextAlignment="Center" />
                
                <Label Text="1. Tap 'Trigger Fade Sequence'.&#x0A;2. Wait for the sequence to complete.&#x0A;3. Tap the red rectangle below.&#x0A;If 'Touch detected!' appears, the bug is fixed. If nothing happens, the 10.0.60 touch event bug is present." 
                       TextColor="LightGray" 
                       FontSize="14" 
                       HorizontalTextAlignment="Center" />

                <!-- ContentView: In GnollHack, SKCanvasView is wrapped in SwitchableCanvasView (which is a ContentView). -->
                <ContentView x:Name="MainCanvasWrapper">
                    <skia:SKCanvasView x:Name="MainCanvasView" 
                                       HeightRequest="200" 
                                       WidthRequest="200"
                                       EnableTouchEvents="True"
                                       Touch="OnCanvasTouch"
                                       PaintSurface="OnCanvasPaintSurface" />
                </ContentView>
                
                <Label x:Name="StatusLabel" 
                       Text="Ready. Tap button to run sequence." 
                       TextColor="Yellow" 
                       FontSize="18" 
                       FontAttributes="Bold" 
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
            
        </Grid>

        <Button Grid.Row="1" 
                x:Name="TriggerBtn"
                Text="Trigger Fade Sequence" 
                Clicked="OnTriggerBugClicked" 
                BackgroundColor="DarkRed" 
                TextColor="White" 
                HeightRequest="50" 
                Margin="10" />
    </Grid>

</ContentPage>
